{
  "rules": {
    "crowdcodeNext": {
      "events": {
        ".read": true,
        "$eventId": {
          ".write": "auth != null"
        }
      },
      "sessions": {
        ".read": true,
        "$sessionCode": {
          ".write": "auth != null"
        }
      },
      "participants": {
        "$sessionCode": {
          ".read": true,
          "$participantId": {
            ".write": true
          }
        }
      }
    }
  }
}
